<Window x:Class="WarrantyRepairCenter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WarrantyRepairCenter"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button x:Name="manageCustomerBtn" Content="Manage customer"
                Height="80" Width="300" Margin="0,0,0,10"
                Click="manageCustomerBtn_Click"/>
            <Button x:Name="manageEmployeeBtn" Content="Manage employee"
                Height="80" Width="300" Margin="0,0,0,10"
                Click="manageEmployeeBtn_Click"/>
            <Button x:Name="manageRepairTicketBtn" Content="Manage repair ticket"
                Height="80" Width="300"
                Click="manageRepairTicketBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
