<Window x:Class="WarrantyRepairCenter.UserInterfaces.EmployeeWnd"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Employees" Height="650" Width="1000" WindowStartupLocation="CenterScreen" Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Employee Management" Style="{StaticResource HeaderTextStyle}" Margin="0,0,0,20"/>

        <!-- Form Section -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,20" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 1 -->
                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <Label Content="Full Name" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtFullName" Style="{StaticResource ModernTextBoxStyle}" Height="38"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2">
                        <Label Content="Username" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtUsername" Style="{StaticResource ModernTextBoxStyle}" Height="38"/>
                    </StackPanel>
                </Grid>

                <!-- Row 2 -->
                <Grid Grid.Row="1" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <Label Content="Role" FontWeight="SemiBold"/>
                        <ComboBox x:Name="cboRole" Style="{StaticResource ModernComboBoxStyle}" Height="38"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2">
                        <Label Content="Status" FontWeight="SemiBold"/>
                        <ComboBox x:Name="cboStatus" Style="{StaticResource ModernComboBoxStyle}" Height="38"/>
                    </StackPanel>
                </Grid>

                <!-- Row 3 (Password) -->
                <Grid Grid.Row="2" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <Label Content="Password (for new user)" FontWeight="SemiBold"/>
                        <PasswordBox x:Name="pwdPassword" Style="{StaticResource ModernPasswordBoxStyle}" Height="38"/>
                    </StackPanel>
                </Grid>

                <!-- Actions -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button x:Name="btnRefresh" Content="🔄 Refresh" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0" Width="100" Click="btnRefresh_Click"/>
                    <Button x:Name="btnAdd" Content="➕ Add New" Style="{StaticResource ModernButtonStyle}" Margin="0,0,10,0" Width="110" Click="btnAdd_Click"/>
                    <Button x:Name="btnEdit" Content="💾 Save Edit" Style="{StaticResource ModernButtonStyle}" Margin="0,0,10,0" Width="110" Click="btnEdit_Click"/>
                    <Button x:Name="btnChangePass" Content="🔑 Change Password" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0" Width="150" Click="btnChangePass_Click"/>
                    <Button x:Name="btnRemove" Content="🗑️ Remove" Style="{StaticResource DangerButtonStyle}" Width="110" Click="btnRemove_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2" x:Name="dgData" Margin="0" Style="{StaticResource ModernDataGridStyle}" AutoGenerateColumns="False" CanUserAddRows="False" SelectionChanged="dgData_SelectionChanged" IsReadOnly="True" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="1.5*"/>
                <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="*"/>
                <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="0.8*"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="0.8*"/>
                <DataGridTextColumn Header="Created Date" Binding="{Binding CreationTime, StringFormat=\{0:yyyy-MM-dd\}}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>