<Window x:Class="WarrantyRepairCenter.UserInterfaces.ChangeMyPasswordWnd"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WarrantyRepairCenter.UserInterfaces"
        mc:Ignorable="d"
        Title="Change Password" Height="300" Width="350" ResizeMode="CanMinimize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Top" Background="Aqua">
            <Label Content="Change password" VerticalAlignment="Top" FontSize="25" HorizontalAlignment="Center" Margin="5" FontWeight="Bold"/>
        </Border>
        <Grid Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="10,5,10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100px"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Label Grid.Row="0" Grid.Column="0" Margin="5" Content="_Old password:" Target="{Binding ElementName=txtOldPass}"/>
            <PasswordBox Grid.Row="0" Grid.Column="1" Margin="5" x:Name="txtOldPass" VerticalContentAlignment="Center"/>
            <Border Grid.Row="1" Grid.Column="0" Margin="5" Background="Transparent"/>
            <Label Grid.Row="2" Grid.Column="0" Margin="5" Content="_New password:" Target="{Binding ElementName=txtNewPass}"/>
            <PasswordBox Grid.Row="2" Grid.Column="1" Margin="5" x:Name="txtNewPass" VerticalContentAlignment="Center"/>
        </Grid>
        <Grid Grid.Row="2" Margin="15,5,15,15" HorizontalAlignment="Stretch" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" x:Name="btnChangePass" Content="_Change" Margin="0,0,0,0" Height="30" MinWidth="100" Click="btnChangePass_Click"/>
            <Button Grid.Column="1" x:Name="btnExit" Content="_Exit" Margin="10,0,0,0" Height="30" MinWidth="100" Click="btnExit_Click"/>
        </Grid>
    </Grid>
</Window>
