<Window x:Class="WarrantyRepairCenter.UserInterfaces.ChangeMyPasswordWnd"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change Password" Height="500" Width="450" 
        WindowStartupLocation="CenterScreen" 
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid>
        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Margin="40" Padding="30">
            <Border.Effect>
                <DropShadowEffect Color="#0F172A" Opacity="0.1" BlurRadius="20" ShadowDepth="4" Direction="270"/>
            </Border.Effect>
            <StackPanel VerticalAlignment="Center">
                <!-- Header -->
                <TextBlock Text="Change Password" Foreground="{StaticResource PrimaryBrush}" Style="{StaticResource HeaderTextStyle}" HorizontalAlignment="Center" FontSize="28" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBlock Text="Secure your account" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                
                <!-- Inputs -->
                <Label Content="Old Password" FontWeight="SemiBold"/>
                <PasswordBox x:Name="txtOldPass" Style="{StaticResource ModernPasswordBoxStyle}" Height="45" Margin="0,0,0,15" FontSize="15"/>
                
                <Label Content="New Password" FontWeight="SemiBold"/>
                <PasswordBox x:Name="txtNewPass" Style="{StaticResource ModernPasswordBoxStyle}" Height="45" Margin="0,0,0,30" FontSize="15"/>
                
                <!-- Actions -->
                <Button x:Name="btnChangePass" Content="Change Password" Style="{StaticResource ModernButtonStyle}" Height="45" Click="btnChangePass_Click" Margin="0,0,0,15"/>
                <Button x:Name="btnExit" Content="Cancel" Style="{StaticResource SecondaryButtonStyle}" Height="45" Click="btnExit_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
