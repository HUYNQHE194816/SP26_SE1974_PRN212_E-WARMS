<Window x:Class="WarrantyRepairCenter.UserInterfaces.ServiceWnd"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Services" Height="600" Width="850" WindowStartupLocation="CenterScreen" Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Service Management" Style="{StaticResource HeaderTextStyle}" Margin="0,0,0,20"/>
        
        <!-- Form Section -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,20" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <Label Content="Service Name" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtName" Style="{StaticResource ModernTextBoxStyle}" Height="38"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2">
                        <Label Content="Base Price" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtBasePrice" Style="{StaticResource ModernTextBoxStyle}" Height="38"/>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="1" Margin="0,0,0,15">
                    <Label Content="Description" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtDesc" Style="{StaticResource ModernTextBoxStyle}" Height="80" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="10"/>
                </StackPanel>

                <!-- Actions -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button x:Name="btnRefresh" Content="🔄 Refresh" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0" Width="100" Click="btnRefresh_Click"/>
                    <Button x:Name="btnAdd" Content="➕ Add New" Style="{StaticResource ModernButtonStyle}" Margin="0,0,10,0" Width="110" Click="btnAdd_Click"/>
                    <Button x:Name="btnEdit" Content="💾 Save Edit" Style="{StaticResource ModernButtonStyle}" Margin="0,0,10,0" Width="110" Click="btnEdit_Click"/>
                    <Button x:Name="btnRemove" Content="🗑️ Remove" Style="{StaticResource DangerButtonStyle}" Width="110" Click="btnRemove_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2" x:Name="dgData" Margin="0" Style="{StaticResource ModernDataGridStyle}" AutoGenerateColumns="False" CanUserAddRows="False" SelectionChanged="dgData_SelectionChanged" IsReadOnly="True" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Service Name" Binding="{Binding Name}" Width="1.5*"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="2*"/>
                <DataGridTextColumn Header="Base Price" Binding="{Binding BasePrice, StringFormat=n0}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
