<Window x:Class="WarrantyRepairCenter.UserInterfaces.ServiceWnd"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WarrantyRepairCenter.UserInterfaces"
        mc:Ignorable="d"
        Title="Service management" Height="450" Width="450">
    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0">
                <Border HorizontalAlignment="Stretch" VerticalAlignment="Top" Background="Aqua">
                    <Label Content="Service management" VerticalAlignment="Top" FontSize="25" HorizontalAlignment="Center" Margin="5" FontWeight="Bold"/>
                </Border>
                <Grid HorizontalAlignment="Stretch" VerticalAlignment="Top" Margin="10,5,10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100px"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Label Grid.Row="0" Grid.Column="0" Margin="5" Content="Name:"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Margin="5" x:Name="txtName" VerticalContentAlignment="Center"/>
                    <Label Grid.Row="1" Grid.Column="0" Margin="5" Content="Description:"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Margin="5" x:Name="txtDesc" AcceptsReturn="True" TextWrapping="Wrap" Height="50"/>
                    <Label Grid.Row="2" Grid.Column="0" Margin="5" Content="Base price:"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Margin="5" x:Name="txtBasePrice" VerticalContentAlignment="Center"/>
                </Grid>
                <StackPanel Grid.Row="2" Margin="5" HorizontalAlignment="Center" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button x:Name="btnRefresh" Content="Refresh" Margin="0,0,0,0" Height="30" MinWidth="80" Click="btnRefresh_Click"/>
                    <Button x:Name="btnAdd" Content="Add" Margin="10,0,0,0" Height="30" MinWidth="80" Click="btnAdd_Click"/>
                    <Button x:Name="btnEdit" Content="Edit" Margin="10,0,0,0" Height="30" MinWidth="80" Click="btnEdit_Click"/>
                    <Button x:Name="btnRemove" Content="Remove" Margin="10,0,0,0" Height="30" MinWidth="80" Click="btnRemove_Click"/>
                </StackPanel>
            </StackPanel>
            <DataGrid Grid.Row="1" x:Name="dgData" Margin="5" AutoGenerateColumns="False" CanUserAddRows="False" SelectionChanged="dgData_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="20*"/>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="40*"/>
                    <DataGridTextColumn Header="Base price" Binding="{Binding BasePrice}" Width="25*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>
