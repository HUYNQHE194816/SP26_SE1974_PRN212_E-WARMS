<Window x:Class="WarrantyRepairCenter.UserInterfaces.DeviceWnd"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WarrantyRepairCenter.UserInterfaces"
        mc:Ignorable="d"
        Title="Device management" Height="550" Width="750" MinHeight="550" MinWidth="750">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0">
            <Border HorizontalAlignment="Stretch" VerticalAlignment="Top" Background="Aqua">
                <Label Content="Device management" VerticalAlignment="Top" FontSize="25" HorizontalAlignment="Center" Margin="5" FontWeight="Bold"/>
            </Border>
            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Top" Margin="10,5,10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Label Grid.Row="0" Grid.Column="0" Margin="5" Content="Customer:"/>
                <ComboBox Grid.Row="0" Grid.Column="1" Margin="5" x:Name="cboCustomer" DisplayMemberPath="Name" SelectedValuePath="ID"/>
                <Label Grid.Row="0" Grid.Column="2" Margin="5" Content="Name:"/>
                <TextBox Grid.Row="0" Grid.Column="3" Margin="5" x:Name="txtName" VerticalContentAlignment="Center"/>
                <Label Grid.Row="1" Grid.Column="0" Margin="5" Content="Type:"/>
                <TextBox Grid.Row="1" Grid.Column="1" Margin="5" x:Name="txtType" VerticalContentAlignment="Center"/>
                <Label Grid.Row="1" Grid.Column="2" Margin="5" Content="Serial:"/>
                <TextBox Grid.Row="1" Grid.Column="3" Margin="5" x:Name="txtSerial" VerticalContentAlignment="Center"/>
                <Label Grid.Row="2" Grid.Column="0" Margin="5" Content="Brand:"/>
                <TextBox Grid.Row="2" Grid.Column="1" Margin="5" x:Name="txtBrand" VerticalContentAlignment="Center"/>
                <Label Grid.Row="2" Grid.Column="2" Margin="5" Content="Model:"/>
                <TextBox Grid.Row="2" Grid.Column="3" Margin="5" x:Name="txtModel" VerticalContentAlignment="Center"/>
                <Label Grid.Row="3" Grid.Column="0" Margin="5" Content="Color:"/>
                <TextBox Grid.Row="3" Grid.Column="1" Margin="5" x:Name="txtColor" VerticalContentAlignment="Center"/>
                <Label Grid.Row="3" Grid.Column="2" Margin="5" Content="Condition:"/>
                <TextBox Grid.Row="3" Grid.Column="3" Margin="5" x:Name="txtCondition" VerticalContentAlignment="Center"/>
                <Label Grid.Row="4" Grid.Column="0" Margin="5" Content="Description:"/>
                <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" Margin="5" x:Name="txtDescription" VerticalContentAlignment="Center"/>
                <Label Grid.Row="5" Grid.Column="0" Margin="5" Content="Notes:"/>
                <TextBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="3" Margin="5" x:Name="txtNotes" VerticalContentAlignment="Center"/>
            </Grid>
            <StackPanel Margin="5" HorizontalAlignment="Center" Orientation="Horizontal" VerticalAlignment="Top">
                <Button x:Name="btnRefresh" Content="Refresh" Margin="0,0,0,0" Height="30" MinWidth="80" Click="btnRefresh_Click"/>
                <Button x:Name="btnAdd" Content="Add" Margin="10,0,0,0" Height="30" MinWidth="80" Click="btnAdd_Click"/>
                <Button x:Name="btnEdit" Content="Edit" Margin="10,0,0,0" Height="30" MinWidth="80" Click="btnEdit_Click"/>
                <Button x:Name="btnRemove" Content="Remove" Margin="10,0,0,0" Height="30" MinWidth="80" Click="btnRemove_Click"/>
            </StackPanel>
        </StackPanel>
        <DataGrid Grid.Row="1" x:Name="dgData" Margin="5" AutoGenerateColumns="False" CanUserAddRows="False" SelectionChanged="dgData_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Customer" Binding="{Binding Customer.Name}" Width="15*"/>
                <DataGridTextColumn Header="Device Name" Binding="{Binding Name}" Width="15*"/>
                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="10*"/>
                <DataGridTextColumn Header="Serial" Binding="{Binding Serial}" Width="12*"/>
                <DataGridTextColumn Header="Brand" Binding="{Binding Brand}" Width="10*"/>
                <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="10*"/>
                <DataGridTextColumn Header="Color" Binding="{Binding Color}" Width="8*"/>
                <DataGridTextColumn Header="Condition" Binding="{Binding PhysicalCondition}" Width="10*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
