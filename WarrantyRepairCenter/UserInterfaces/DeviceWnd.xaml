<Window x:Class="WarrantyRepairCenter.UserInterfaces.DeviceWnd"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Devices" Height="750" Width="1100" WindowStartupLocation="CenterScreen" Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Device Management" Style="{StaticResource HeaderTextStyle}" Margin="0,0,0,20"/>
        
        <!-- Form Section -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,20" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 1 -->
                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <Label Content="Customer Owner" FontWeight="SemiBold"/>
                        <ComboBox x:Name="cboCustomer" Style="{StaticResource ModernComboBoxStyle}" Height="38" DisplayMemberPath="Name" SelectedValuePath="ID"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2">
                        <Label Content="Device Name" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtName" Style="{StaticResource ModernTextBoxStyle}" Height="38"/>
                    </StackPanel>
                </Grid>

                <!-- Row 2 -->
                <Grid Grid.Row="1" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <Label Content="Device Type" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtType" Style="{StaticResource ModernTextBoxStyle}" Height="38" Tag="e.g. Smartphone, Laptop..."/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2">
                        <Label Content="Serial Number" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtSerial" Style="{StaticResource ModernTextBoxStyle}" Height="38"/>
                    </StackPanel>
                </Grid>

                <!-- Row 3 -->
                <Grid Grid.Row="2" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <Label Content="Brand" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtBrand" Style="{StaticResource ModernTextBoxStyle}" Height="38"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2">
                        <Label Content="Model" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtModel" Style="{StaticResource ModernTextBoxStyle}" Height="38"/>
                    </StackPanel>
                </Grid>

                <!-- Row 4 -->
                <Grid Grid.Row="3" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <Label Content="Color" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtColor" Style="{StaticResource ModernTextBoxStyle}" Height="38"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2">
                        <Label Content="Condition" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtCondition" Style="{StaticResource ModernTextBoxStyle}" Height="38"/>
                    </StackPanel>
                </Grid>

                <!-- Row 5 (Full Width) -->
                <StackPanel Grid.Row="4" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <Label Content="Problem Description" FontWeight="SemiBold"/>
                            <TextBox x:Name="txtDescription" Style="{StaticResource ModernTextBoxStyle}" Height="38"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <Label Content="Additional Notes" FontWeight="SemiBold"/>
                            <TextBox x:Name="txtNotes" Style="{StaticResource ModernTextBoxStyle}" Height="38"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- Actions -->
                <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button x:Name="btnRefresh" Content="🔄 Refresh" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0" Width="100" Click="btnRefresh_Click"/>
                    <Button x:Name="btnAdd" Content="➕ Add New" Style="{StaticResource ModernButtonStyle}" Margin="0,0,10,0" Width="110" Click="btnAdd_Click"/>
                    <Button x:Name="btnEdit" Content="💾 Save Edit" Style="{StaticResource ModernButtonStyle}" Margin="0,0,10,0" Width="110" Click="btnEdit_Click"/>
                    <Button x:Name="btnRemove" Content="🗑️ Remove" Style="{StaticResource DangerButtonStyle}" Width="110" Click="btnRemove_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2" x:Name="dgData" Margin="0" Style="{StaticResource ModernDataGridStyle}" AutoGenerateColumns="False" CanUserAddRows="False" SelectionChanged="dgData_SelectionChanged" IsReadOnly="True" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Customer" Binding="{Binding Customer.Name}" Width="*"/>
                <DataGridTextColumn Header="Device Name" Binding="{Binding Name}" Width="1.2*"/>
                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="*"/>
                <DataGridTextColumn Header="Serial" Binding="{Binding Serial}" Width="*"/>
                <DataGridTextColumn Header="Brand" Binding="{Binding Brand}" Width="*"/>
                <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="*"/>
                <DataGridTextColumn Header="Color" Binding="{Binding Color}" Width="*"/>
                <DataGridTextColumn Header="Condition" Binding="{Binding PhysicalCondition}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
