<Window x:Class="WarrantyRepairCenter.UserInterfaces.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="E-WARMS | Secure Login" Height="550" Width="850" 
        WindowStartupLocation="CenterScreen" 
        ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border CornerRadius="16" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0" Margin="25">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.25" BlurRadius="25" ShadowDepth="8" Direction="270"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Banner Side -->
            <Border Grid.Column="0" CornerRadius="16,0,0,16" ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0F172A" Offset="0"/>
                        <GradientStop Color="#2563EB" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <!-- Abstract Background Shapes -->
                    <Ellipse Width="350" Height="350" Fill="#FFFFFF" Opacity="0.04" Margin="-120,-120,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                    <Ellipse Width="250" Height="250" Fill="#FFFFFF" Opacity="0.07" Margin="0,0,-80,-80" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                    
                    <StackPanel VerticalAlignment="Center" Margin="40">
                        <TextBlock Text="E-WARMS" Foreground="#FFFFFF" FontSize="42" FontWeight="Black" Margin="0,0,0,10" FontFamily="Segoe UI"/>
                        <TextBlock Text="Enterprise Warranty &amp;&#x0a;Repair Management System" Foreground="#E2E8F0" FontSize="18" TextWrapping="Wrap" LineHeight="28" FontWeight="SemiBold"/>
                        
                        <Path Fill="#3B82F6" Margin="0,40,0,0" Data="M0,0 L60,0 L60,4 L0,4 Z" HorizontalAlignment="Left" Width="60" Stretch="Fill"/>
                        
                        <TextBlock Text="Streamline your workflow. Manage customers, tracks devices, and assign repair tickets effortlessly in one unified platform." Foreground="#94A3B8" FontSize="14" Margin="0,20,0,0" TextWrapping="Wrap" LineHeight="22"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Right Login Form Side -->
            <Grid Grid.Column="1" Margin="30">
                <!-- Close Button -->
                <Button Content="✕" Width="32" Height="32" HorizontalAlignment="Right" VerticalAlignment="Top" 
                        Background="Transparent" BorderThickness="0" Foreground="#64748B" FontSize="16" Cursor="Hand"
                        Click="btnExit_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="16">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#F1F5F9"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <StackPanel VerticalAlignment="Center" Margin="20,0">
                    <TextBlock Text="Welcome Back 👋" FontSize="30" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="Please sign in to your dashboard account" FontSize="15" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,40"/>
                    
                    <!-- Username -->
                    <Label Content="Username" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtUsername" Style="{StaticResource ModernTextBoxStyle}" Height="48" FontSize="15" Margin="0,0,0,20"/>
                    
                    <!-- Password -->
                    <Label Content="Password" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="txtPassword" Style="{StaticResource ModernPasswordBoxStyle}" Height="48" FontSize="15" Margin="0,0,0,10"/>
                    
                    <!-- Buttons -->
                    <Button x:Name="btnLogin" Content="Sign In" Style="{StaticResource ModernButtonStyle}" Height="50" FontSize="16" Click="btnLogin_Click" Margin="0,40,0,0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
