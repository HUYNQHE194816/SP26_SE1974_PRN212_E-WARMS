<Window x:Class="WarrantyRepairCenter.UserInterfaces.SparePartWnd"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WarrantyRepairCenter.UserInterfaces"
        mc:Ignorable="d"
        Title="Spare part management" Height="400" Width="500" MinHeight="400" MinWidth="500">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0">
            <Border HorizontalAlignment="Stretch" VerticalAlignment="Top" Background="Aqua">
                <Label Content="Spare part management" VerticalAlignment="Top" FontSize="25" HorizontalAlignment="Center" Margin="5" FontWeight="Bold"/>
            </Border>
            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Top" Margin="10,5,10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Label Grid.Row="0" Grid.Column="0" Margin="5" Content="Name:"/>
                <TextBox Grid.Row="0" Grid.Column="1" Margin="5" x:Name="txtName" VerticalContentAlignment="Center" TextChanged="txtName_TextChanged"/>
                <Label Grid.Row="0" Grid.Column="2" Margin="5" Content="SKU:"/>
                <TextBox Grid.Row="0" Grid.Column="3" Margin="5" x:Name="txtSKU" VerticalContentAlignment="Center" IsReadOnly="True"/>
                <Label Grid.Row="1" Grid.Column="0" Margin="5" Content="Import price:"/>
                <TextBox Grid.Row="1" Grid.Column="1" Margin="5" x:Name="txtImportPrice" VerticalContentAlignment="Center"/>
                <Label Grid.Row="1" Grid.Column="2" Margin="5" Content="Selling price:"/>
                <TextBox Grid.Row="1" Grid.Column="3" Margin="5" x:Name="txtSellingPrice" VerticalContentAlignment="Center"/>
                <Label Grid.Row="2" Grid.Column="0" Margin="5" Content="Stock:"/>
                <TextBox Grid.Row="2" Grid.Column="1" Margin="5" x:Name="txtStockQuantity" VerticalContentAlignment="Center"/>
                <Label Grid.Row="2" Grid.Column="2" Margin="5" Content="Warranty month:"/>
                <TextBox Grid.Row="2" Grid.Column="3" Margin="5" x:Name="txtWarrantyPeriodMonth" VerticalContentAlignment="Center"/>
            </Grid>
            <StackPanel Grid.Row="2" Margin="5" HorizontalAlignment="Center" Orientation="Horizontal" VerticalAlignment="Top">
                <Button x:Name="btnRefresh" Content="Refresh" Margin="0,0,0,0" Height="30" MinWidth="80" Click="btnRefresh_Click"/>
                <Button x:Name="btnAdd" Content="Add" Margin="10,0,0,0" Height="30" MinWidth="80" Click="btnAdd_Click"/>
                <Button x:Name="btnEdit" Content="Edit" Margin="10,0,0,0" Height="30" MinWidth="80" Click="btnEdit_Click"/>
                <Button x:Name="btnRemove" Content="Remove" Margin="10,0,0,0" Height="30" MinWidth="80" Click="btnRemove_Click"/>
            </StackPanel>
        </StackPanel>
        <DataGrid Grid.Row="1" x:Name="dgData" Margin="5" AutoGenerateColumns="False" CanUserAddRows="False" SelectionChanged="dgData_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="20*"/>
                <DataGridTextColumn Header="SKU" Binding="{Binding SKU}" Width="15*"/>
                <DataGridTextColumn Header="Import price" Binding="{Binding ImportPrice}" Width="15*"/>
                <DataGridTextColumn Header="Selling price" Binding="{Binding SellingPrice}" Width="15*"/>
                <DataGridTextColumn Header="Stock" Binding="{Binding StockQuantity}" Width="12*"/>
                <DataGridTextColumn Header="Warranty month" Binding="{Binding WarrantyPeriodMonth}" Width="15*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
