<Window x:Class="WarrantyRepairCenter.UserInterfaces.SparePartWnd"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Spare Parts" Height="650" Width="1000" WindowStartupLocation="CenterScreen" Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Spare Part Management" Style="{StaticResource HeaderTextStyle}" Margin="0,0,0,20"/>
        
        <!-- Form Section -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,20" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 1 -->
                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <Label Content="Part Name" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtName" Style="{StaticResource ModernTextBoxStyle}" Height="38" TextChanged="txtName_TextChanged"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2">
                        <Label Content="SKU (Auto-generated)" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtSKU" Style="{StaticResource ModernTextBoxStyle}" Height="38" IsReadOnly="True" Background="{StaticResource BackgroundBrush}"/>
                    </StackPanel>
                </Grid>

                <!-- Row 2 -->
                <Grid Grid.Row="1" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <Label Content="Import Price" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtImportPrice" Style="{StaticResource ModernTextBoxStyle}" Height="38"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2">
                        <Label Content="Selling Price" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtSellingPrice" Style="{StaticResource ModernTextBoxStyle}" Height="38"/>
                    </StackPanel>
                </Grid>

                <!-- Row 3 -->
                <Grid Grid.Row="2" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <Label Content="Stock Quantity" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtStockQuantity" Style="{StaticResource ModernTextBoxStyle}" Height="38"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2">
                        <Label Content="Warranty Period (Months)" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtWarrantyPeriodMonth" Style="{StaticResource ModernTextBoxStyle}" Height="38"/>
                    </StackPanel>
                </Grid>

                <!-- Actions -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button x:Name="btnRefresh" Content="🔄 Refresh" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0" Width="100" Click="btnRefresh_Click"/>
                    <Button x:Name="btnAdd" Content="➕ Add New" Style="{StaticResource ModernButtonStyle}" Margin="0,0,10,0" Width="110" Click="btnAdd_Click"/>
                    <Button x:Name="btnEdit" Content="💾 Save Edit" Style="{StaticResource ModernButtonStyle}" Margin="0,0,10,0" Width="110" Click="btnEdit_Click"/>
                    <Button x:Name="btnRemove" Content="🗑️ Remove" Style="{StaticResource DangerButtonStyle}" Width="110" Click="btnRemove_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2" x:Name="dgData" Margin="0" Style="{StaticResource ModernDataGridStyle}" AutoGenerateColumns="False" CanUserAddRows="False" SelectionChanged="dgData_SelectionChanged" IsReadOnly="True" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Part Name" Binding="{Binding Name}" Width="1.5*"/>
                <DataGridTextColumn Header="SKU" Binding="{Binding SKU}" Width="*"/>
                <DataGridTextColumn Header="Import Price" Binding="{Binding ImportPrice, StringFormat=n0}" Width="*"/>
                <DataGridTextColumn Header="Selling Price" Binding="{Binding SellingPrice, StringFormat=n0}" Width="*"/>
                <DataGridTextColumn Header="Stock" Binding="{Binding StockQuantity}" Width="0.8*"/>
                <DataGridTextColumn Header="Warranty" Binding="{Binding WarrantyPeriodMonth}" Width="0.8*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
