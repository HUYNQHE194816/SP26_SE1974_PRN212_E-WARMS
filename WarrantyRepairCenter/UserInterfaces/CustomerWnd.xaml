<Window x:Class="WarrantyRepairCenter.UserInterfaces.CustomerWnd"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Customers" Height="650" Width="1000" WindowStartupLocation="CenterScreen" Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header Section -->
        <TextBlock Grid.Row="0" Text="Customer Management" Style="{StaticResource HeaderTextStyle}" Margin="0,0,0,20"/>
        
        <!-- Form Section -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,20" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Margin="0,0,0,15">
                        <Label Content="Customer Name" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtName" Style="{StaticResource ModernTextBoxStyle}" Height="38"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2" Margin="0,0,0,15">
                        <Label Content="Email Address" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtEmail" Style="{StaticResource ModernTextBoxStyle}" Height="38"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Margin="0,0,0,15">
                        <Label Content="Phone Number" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtPhone" Style="{StaticResource ModernTextBoxStyle}" Height="38"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2" Margin="0,0,0,15">
                        <Label Content="Address" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtAddress" Style="{StaticResource ModernTextBoxStyle}" Height="38"/>
                    </StackPanel>
                </Grid>

                <!-- Actions -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button x:Name="btnRefresh" Content="🔄 Refresh" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0" Width="100" Click="btnRefresh_Click"/>
                    <Button x:Name="btnAdd" Content="➕ Add New" Style="{StaticResource ModernButtonStyle}" Margin="0,0,10,0" Width="110" Click="btnAdd_Click"/>
                    <Button x:Name="btnEdit" Content="💾 Save Edit" Style="{StaticResource ModernButtonStyle}" Margin="0,0,10,0" Width="110" Click="btnEdit_Click"/>
                    <Button x:Name="btnRemove" Content="🗑️ Remove" Style="{StaticResource DangerButtonStyle}" Width="110" Click="btnRemove_Click"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- DataGrid Section -->
        <DataGrid Grid.Row="2" x:Name="dgData" Margin="0" Style="{StaticResource ModernDataGridStyle}" AutoGenerateColumns="False" CanUserAddRows="False" SelectionChanged="dgData_SelectionChanged" IsReadOnly="True" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Customer Name" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Email Address" Binding="{Binding Email}" Width="*"/>
                <DataGridTextColumn Header="Phone Number" Binding="{Binding PhoneNumber}" Width="150"/>
                <DataGridTextColumn Header="Physical Address" Binding="{Binding Address}" Width="1.5*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>