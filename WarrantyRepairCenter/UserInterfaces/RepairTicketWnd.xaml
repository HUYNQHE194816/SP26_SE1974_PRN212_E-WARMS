<Window x:Class="WarrantyRepairCenter.UserInterfaces.RepairTicketWnd"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Repair Ticket Management" Height="620" Width="820">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <Border HorizontalAlignment="Stretch" Background="LightSalmon">
                <Label Content="Repair Ticket Management" FontSize="25"
                       HorizontalAlignment="Center" Margin="5" FontWeight="Bold"/>
            </Border>

            <Grid HorizontalAlignment="Stretch" Margin="10,5,10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Margin="5" Content="Device:"/>
                <ComboBox Grid.Row="0" Grid.Column="1" Margin="5" x:Name="cboDevice"
                          DisplayMemberPath="Name"/>

                <Label Grid.Row="1" Grid.Column="0" Margin="5" Content="Condition:"/>
                <TextBox Grid.Row="1" Grid.Column="1" Margin="5" x:Name="txtCondition"/>

                <Label Grid.Row="2" Grid.Column="0" Margin="5" Content="Diagnosis:"/>
                <TextBox Grid.Row="2" Grid.Column="1" Margin="5" x:Name="txtDiagnosis"/>

                <Label Grid.Row="3" Grid.Column="0" Margin="5" Content="Notes:"/>
                <TextBox Grid.Row="3" Grid.Column="1" Margin="5" x:Name="txtNotes"/>

                <Label Grid.Row="0" Grid.Column="2" Margin="5" Content="Status:"/>
                <ComboBox Grid.Row="0" Grid.Column="3" Margin="5" x:Name="cboStatus"/>

                <Label Grid.Row="1" Grid.Column="2" Margin="5" Content="Technician:"/>
                <ComboBox Grid.Row="1" Grid.Column="3" Margin="5" x:Name="cboTechnician"
                          DisplayMemberPath="FullName"/>

                <Label Grid.Row="2" Grid.Column="2" Margin="5" Content="Appointment:"/>
                <DatePicker Grid.Row="2" Grid.Column="3" Margin="5" x:Name="dpAppointment"/>

                <Label Grid.Row="3" Grid.Column="2" Margin="5" Content="Deposit:"/>
                <TextBox Grid.Row="3" Grid.Column="3" Margin="5" x:Name="txtDeposit"/>

                <Label Grid.Row="4" Grid.Column="2" Margin="5" Content="Total Amount:"/>
                <TextBox Grid.Row="4" Grid.Column="3" Margin="5" x:Name="txtTotalAmount"/>
            </Grid>

            <StackPanel Margin="5" HorizontalAlignment="Center" Orientation="Horizontal">
                <Button x:Name="btnRefresh" Content="Refresh"
                        Height="30" MinWidth="80" Click="btnRefresh_Click"/>
                <Button x:Name="btnAdd" Content="Add"
                        Margin="10,0,0,0" Height="30" MinWidth="80" Click="btnAdd_Click"/>
                <Button x:Name="btnEdit" Content="Edit"
                        Margin="10,0,0,0" Height="30" MinWidth="80" Click="btnEdit_Click"/>
                <Button x:Name="btnRemove" Content="Remove"
                        Margin="10,0,0,0" Height="30" MinWidth="80" Click="btnRemove_Click"/>
            </StackPanel>
        </StackPanel>

        <DataGrid Grid.Row="1" x:Name="dgData" Margin="5"
                  AutoGenerateColumns="False" CanUserAddRows="False"
                  SelectionChanged="dgData_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Ticket Code"
                                    Binding="{Binding TicketCode}" Width="25*"/>
                <DataGridTextColumn Header="Device"
                                    Binding="{Binding Device.Name}" Width="15*"/>
                <DataGridTextColumn Header="Customer"
                                    Binding="{Binding Device.Customer.Name}" Width="15*"/>
                <DataGridTextColumn Header="Status"
                                    Binding="{Binding Status}" Width="15*"/>
                <DataGridTextColumn Header="Technician"
                                    Binding="{Binding Technician.FullName}" Width="15*"/>
                <DataGridTextColumn Header="Appointment"
                                    Binding="{Binding AppointmentDate, StringFormat=\{0:yyyy-MM-dd\}}"
                                    Width="15*"/>
                <DataGridTextColumn Header="Total"
                                    Binding="{Binding TotalAmount, StringFormat=\{0:N0\}}"
                                    Width="10*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>