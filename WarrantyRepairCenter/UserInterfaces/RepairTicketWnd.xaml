<Window x:Class="WarrantyRepairCenter.UserInterfaces.RepairTicketWnd"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Repair Tickets" Height="750" Width="1100" WindowStartupLocation="CenterScreen" Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Repair Ticket Management" Style="{StaticResource HeaderTextStyle}" Margin="0,0,0,20"/>

        <!-- Form Section -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,20" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 1 -->
                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <Label Content="Target Device" FontWeight="SemiBold"/>
                        <ComboBox x:Name="cboDevice" Style="{StaticResource ModernComboBoxStyle}" Height="38" DisplayMemberPath="Name"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2">
                        <Label Content="Ticket Status" FontWeight="SemiBold"/>
                        <ComboBox x:Name="cboStatus" Style="{StaticResource ModernComboBoxStyle}" Height="38"/>
                    </StackPanel>
                </Grid>

                <!-- Row 2 -->
                <Grid Grid.Row="1" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <Label Content="Reported Condition" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtCondition" Style="{StaticResource ModernTextBoxStyle}" Height="38"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2">
                        <Label Content="Assigned Technician" FontWeight="SemiBold"/>
                        <ComboBox x:Name="cboTechnician" Style="{StaticResource ModernComboBoxStyle}" Height="38" DisplayMemberPath="FullName"/>
                    </StackPanel>
                </Grid>

                <!-- Row 3 -->
                <Grid Grid.Row="2" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <Label Content="Technician Diagnosis" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtDiagnosis" Style="{StaticResource ModernTextBoxStyle}" Height="38"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2">
                        <Label Content="Appointment Date" FontWeight="SemiBold"/>
                        <DatePicker x:Name="dpAppointment" Height="38" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"/>
                    </StackPanel>
                </Grid>

                <!-- Row 4 -->
                <Grid Grid.Row="3" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <Label Content="Additional Notes" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtNotes" Style="{StaticResource ModernTextBoxStyle}" Height="38"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2">
                        <Label Content="Deposit Amount" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtDeposit" Style="{StaticResource ModernTextBoxStyle}" Height="38"/>
                    </StackPanel>
                </Grid>

                <!-- Row 5 -->
                <Grid Grid.Row="4" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="2">
                        <Label Content="Total Fixed Amount" FontWeight="Bold" Foreground="{StaticResource DangerBrush}"/>
                        <TextBox x:Name="txtTotalAmount" Style="{StaticResource ModernTextBoxStyle}" Height="38"/>
                    </StackPanel>
                </Grid>

                <!-- Actions -->
                <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button x:Name="btnRefresh" Content="🔄 Refresh" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0" Width="100" Click="btnRefresh_Click"/>
                    <Button x:Name="btnAdd" Content="➕ Add New" Style="{StaticResource ModernButtonStyle}" Margin="0,0,10,0" Width="110" Click="btnAdd_Click"/>
                    <Button x:Name="btnEdit" Content="💾 Save Edit" Style="{StaticResource ModernButtonStyle}" Margin="0,0,10,0" Width="110" Click="btnEdit_Click"/>
                    <Button x:Name="btnRemove" Content="🗑️ Remove" Style="{StaticResource DangerButtonStyle}" Width="110" Click="btnRemove_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2" x:Name="dgData" Margin="0" Style="{StaticResource ModernDataGridStyle}" AutoGenerateColumns="False" CanUserAddRows="False" SelectionChanged="dgData_SelectionChanged" IsReadOnly="True" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Ticket Code" Binding="{Binding TicketCode}" Width="1.5*"/>
                <DataGridTextColumn Header="Device" Binding="{Binding Device.Name}" Width="*"/>
                <DataGridTextColumn Header="Customer" Binding="{Binding Device.Customer.Name}" Width="*"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                <DataGridTextColumn Header="Technician" Binding="{Binding Technician.FullName}" Width="*"/>
                <DataGridTextColumn Header="Appt Date" Binding="{Binding AppointmentDate, StringFormat=\{0:yyyy-MM-dd\}}" Width="*"/>
                <DataGridTextColumn Header="Total Amount" Binding="{Binding TotalAmount, StringFormat=\{0:N0\}}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>